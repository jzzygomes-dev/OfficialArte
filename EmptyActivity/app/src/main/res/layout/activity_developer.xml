<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="32dp">

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="start"
        android:background="@android:color/transparent"
        android:contentDescription="@string/back"
        android:src="@drawable/ic_back"
        android:scaleType="centerInside"
        android:layout_marginBottom="24dp" />

    <ImageView
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:src="@mipmap/ic_launcher_foreground"
        android:contentDescription="@string/developer" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/dev_name"
        android:textColor="@color/white"
        android:textSize="24sp"
        android:fontFamily="sans-serif-medium" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/dev_role"
        android:textColor="@color/accent"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/devEmail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:drawableStart="@drawable/ic_email"
        android:drawablePadding="12dp"
        android:text="@string/dev_email"
        android:textColor="@color/gray_light"
        android:textSize="15sp"
        android:clickable="true"
        android:focusable="true" />

    <TextView
        android:id="@+id/devGithub"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:drawableStart="@drawable/ic_link"
        android:drawablePadding="12dp"
        android:text="@string/dev_github"
        android:textColor="@color/gray_light"
        android:textSize="15sp"
        android:clickable="true"
        android:focusable="true" />

    <TextView
        android:id="@+id/devInstagram"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:drawableStart="@drawable/ic_link"
        android:drawablePadding="12dp"
        android:text="@string/dev_instagram"
        android:textColor="@color/gray_light"
        android:textSize="15sp"
        android:clickable="true"
        android:focusable="true" />

</LinearLayout>
